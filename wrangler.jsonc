{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "skill-wanderer-landing-page",
  "main": ".output/server/index.mjs",
  "compatibility_date": "2025-04-19",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".output/public/",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
