# ===========================================
# Firebase Configuration
# ===========================================
NUXT_PUBLIC_FIREBASE_API_KEY=
NUXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NUXT_PUBLIC_FIREBASE_PROJECT_ID=
NUXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NUXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FIREBASE_APP_ID=
NUXT_PUBLIC_MEASUREMENT_ID=

# ===========================================
# Pathfinder Chatbot Configuration
# ===========================================

# Pathfinder API base URL (no trailing slash)
# Local development:
NUXT_PUBLIC_PATHFINDER_API_URL=http://localhost:8000
# Production (set via NUXT_PUBLIC_PATHFINDER_API_URL env var or K8s secret):
# NUXT_PUBLIC_PATHFINDER_API_URL=https://pathfinder.skill-wanderer.com

# Domain filter — comma-separated list of domains Pathfinder searches across
NUXT_PUBLIC_PATHFINDER_DOMAINS=skill-wanderer.com,wanderings.skill-wanderer.com,dojo.skill-wanderer.com

# Chat session expiry time in minutes (default: 30)
NUXT_PUBLIC_PATHFINDER_SESSION_EXPIRY_MINUTES=30

# Chat session storage: "tab" (sessionStorage) or "browser" (localStorage with expiry)
NUXT_PUBLIC_PATHFINDER_SESSION_STORAGE=browser
